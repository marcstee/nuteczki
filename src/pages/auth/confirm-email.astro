---
import Layout from "@/layouts/Layout.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: "Rejestracja zakończona",
      description: "Twoje konto zostało założone. Możesz się teraz zalogować.",
      linkText: "Przejdź do logowania",
    }
  : {
      emoji: "📧",
      heading: "Sprawdź e-mail",
      description: "Wysłaliśmy link potwierdzający na Twój adres e-mail. Kliknij go, aby aktywować konto.",
      linkText: "Powrót do logowania",
    };
---

<Layout title={content.heading}>
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-foreground w-full max-w-sm rounded-2xl border p-8 text-center">
      <div class="mb-4 text-5xl">{content.emoji}</div>
      <h1 class="text-primary mb-3 text-2xl font-bold">
        {content.heading}
      </h1>
      <p class="text-muted-foreground mb-6">{content.description}</p>
      <a href="/auth/signin" class="text-secondary text-sm hover:underline">
        {content.linkText}
      </a>
    </div>
  </div>
</Layout>
