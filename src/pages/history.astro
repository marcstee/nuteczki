---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { summarizeSessions, type SessionSummary } from "@/components/history/sessionSummary";

/**
 * Session history (S-04 / FR-009): a read-only, zero-client-JS list of the
 * signed-in parent's finished drill sessions, newest first. Mirrors the
 * SSR-fetch-in-frontmatter pattern from `drill.astro`: build the cookie-authed
 * client (null-guarded), run one embedded select, and aggregate in TS via the
 * pure `summarizeSessions` helper. RLS scopes every row to the caller, so the
 * result is already account-private.
 *
 * Three render states are kept distinct (see plan-review F1): `sessions === null`
 * is the error / unconfigured-client state (neutral card, no CTA); an empty array
 * is a confirmed first-run user (empty state with the "Zacznij ćwiczyć" CTA); a
 * non-empty array is the list. Collapsing error into empty would tell a returning
 * parent — mid-outage — that their child never practised, so the split is load-bearing.
 */
const supabase = createClient(Astro.request.headers, Astro.cookies);

let sessions: SessionSummary[] | null = null;
if (supabase) {
  const { data, error } = await supabase
    .from("sessions")
    .select("id, started_at, answers(exercise_type, is_correct)")
    .not("finished_at", "is", null)
    .order("started_at", { ascending: false });
  if (!error) {
    sessions = summarizeSessions(data);
  }
}

/**
 * Date-only, explicit Europe/Warsaw tz: the frontmatter runs per-request on a
 * Cloudflare Worker (UTC clock) with zero client JS, so a UTC-formatted date would
 * show the wrong day near local midnight for the Polish audience (plan-review F2).
 * Time-of-day is dropped — it would need the visitor's tz, unavailable without an
 * island. Revisit by moving formatting client-side if the audience goes multi-tz.
 */
const dateFormatter = new Intl.DateTimeFormat("pl-PL", { timeZone: "Europe/Warsaw", dateStyle: "medium" });
---

<Layout title="Historia sesji">
  <div class="min-h-screen p-4">
    <main class="text-foreground mx-auto w-full max-w-2xl py-10">
      <a
        href="/dashboard"
        class="text-muted-foreground hover:text-foreground mb-6 inline-block text-sm transition-colors"
      >
        ← Panel
      </a>
      <h1 class="text-primary mb-8 text-center text-3xl font-bold">Historia sesji</h1>

      {
        sessions === null ? (
          <div class="border-border bg-card mx-auto max-w-md rounded-2xl border p-8 text-center">
            <p class="text-muted-foreground">Nie udało się wczytać sesji. Spróbuj ponownie za chwilę.</p>
          </div>
        ) : sessions.length === 0 ? (
          <div class="border-border bg-card mx-auto max-w-md rounded-2xl border p-8 text-center">
            <p class="text-foreground text-lg font-medium">Brak sesji ćwiczeń</p>
            <p class="text-muted-foreground mt-2 text-sm">Ukończ ćwiczenie, a pojawi się tutaj.</p>
            <a
              href="/drill"
              class="bg-primary text-primary-foreground hover:bg-primary/90 mt-6 block rounded-xl px-6 py-3 text-lg font-bold transition-all"
            >
              Zacznij ćwiczyć
            </a>
          </div>
        ) : (
          <ul class="flex flex-col gap-6">
            {sessions.map((s) => (
              <li class="border-border bg-card rounded-2xl border p-6">
                <div class="mb-4 flex items-baseline justify-between gap-4">
                  <h2 class="text-foreground text-lg font-semibold">{dateFormatter.format(new Date(s.startedAt))}</h2>
                  <span class="text-foreground text-2xl font-bold">{s.accuracyPct}%</span>
                </div>

                <div class="mb-6">
                  <div class="bg-muted h-2 w-full overflow-hidden rounded-full">
                    <div class="bg-primary h-full rounded-full" style={`width: ${s.accuracyPct}%`} />
                  </div>
                  <p class="text-muted-foreground mt-1 text-right text-xs">celność</p>
                </div>

                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                  {[
                    { label: "Nuta → litera", stats: s.byType.noteToLetter },
                    { label: "Litera → nuta", stats: s.byType.letterToNote },
                  ].map(({ label, stats }) => (
                    <div class="border-border bg-background rounded-2xl border p-4">
                      <p class="text-muted-foreground mb-3 text-center text-xs font-semibold tracking-wide uppercase">
                        {label}
                      </p>
                      <div class="flex justify-around">
                        <div class="text-center">
                          <div class="text-success text-3xl font-bold">{stats.correct}</div>
                          <div class="text-muted-foreground text-sm">poprawne</div>
                        </div>
                        <div class="text-center">
                          <div class="text-destructive text-3xl font-bold">{stats.incorrect}</div>
                          <div class="text-muted-foreground text-sm">błędne</div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </div>
</Layout>
