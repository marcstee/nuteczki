---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Dashboard
      </h1>
      <p class="text-blue-100/80">
        Welcome, <span class="font-semibold text-white">{user?.email}</span>
      </p>
      <p class="mt-2 text-sm text-blue-100/50">This page is only for authenticated users.</p>
      <a
        href="/drill"
        class="mt-6 block rounded-xl bg-gradient-to-r from-blue-500 to-purple-500 px-6 py-3 text-lg font-bold text-white transition-all hover:from-blue-400 hover:to-purple-400"
      >
        Start practising
      </a>
      <a
        href="/history"
        class="mt-3 block rounded-xl border border-white/20 bg-white/5 px-6 py-3 text-lg font-semibold text-white transition-colors hover:bg-white/10"
      >
        Session history
      </a>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
