---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="Panel">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-card-foreground w-full max-w-md rounded-2xl border p-8 text-center">
      <img
        src="/mascot.webp"
        alt="Uśmiechnięta maskotka Nuteczek"
        width="160"
        height="160"
        class="mx-auto mb-4 h-28 w-28"
      />
      <h1 class="text-foreground mb-2 text-3xl font-bold">Cześć!</h1>
      <p class="text-muted-foreground">
        Zalogowano jako <span class="text-foreground font-semibold">{user?.email}</span>
      </p>
      <a
        href="/drill"
        class="bg-primary text-primary-foreground hover:bg-primary/90 mt-6 block rounded-2xl px-6 py-4 text-lg font-bold transition-colors"
      >
        Zacznij ćwiczyć
      </a>
      <a
        href="/history"
        class="bg-secondary text-secondary-foreground hover:bg-secondary/90 mt-3 block rounded-2xl px-6 py-4 text-lg font-semibold transition-colors"
      >
        Historia sesji
      </a>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="border-border text-muted-foreground hover:text-foreground rounded-xl border px-4 py-2 text-sm transition-colors"
        >
          Wyloguj
        </button>
      </form>
    </div>
  </div>
</Layout>
