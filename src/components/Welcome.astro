---
import Topbar from "@/components/Topbar.astro";
---

<div class="min-h-screen w-full p-4 sm:p-8">
  <Topbar />

  <div class="mx-auto flex max-w-2xl flex-col items-center justify-center px-4 py-16 text-center sm:py-24">
    <img
      src="/mascot.webp"
      alt="Uśmiechnięta maskotka Nuteczek"
      width="256"
      height="256"
      class="mb-8 h-40 w-40 sm:h-56 sm:w-56"
    />
    <h1 class="text-foreground mb-4 text-5xl font-bold sm:text-6xl">Nuteczki</h1>
    <p class="text-muted-foreground mb-10 max-w-md text-lg sm:text-xl">
      Naucz się czytać nutki — wesoła zabawa dla małych muzyków!
    </p>
    <div class="flex w-full flex-col gap-4 sm:w-auto sm:flex-row">
      <a
        href="/auth/signin"
        class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center justify-center rounded-2xl px-8 py-4 text-lg font-semibold transition-colors"
      >
        Zaloguj się
      </a>
      <a
        href="/auth/signup"
        class="bg-secondary text-secondary-foreground hover:bg-secondary/90 inline-flex items-center justify-center rounded-2xl px-8 py-4 text-lg font-semibold transition-colors"
      >
        Zarejestruj się
      </a>
    </div>
  </div>
</div>
