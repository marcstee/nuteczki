---
type Variant = "info" | "warning" | "error";

interface Props {
  variant?: Variant;
}

const { variant = "info" } = Astro.props;
---

<div class:list={["banner", `banner--${variant}`]} role={variant === "error" ? "alert" : "status"}>
  <slot />
</div>

<style>
  .banner {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    text-align: center;
    border-bottom: 1px solid;
  }
  .banner :global(a) {
    color: inherit;
    text-decoration: underline;
    font-weight: 600;
  }
  .banner--info {
    background: color-mix(in oklab, var(--primary) 16%, var(--background));
    color: var(--foreground);
    border-color: var(--primary);
  }
  .banner--warning {
    background: color-mix(in oklab, var(--accent) 16%, var(--background));
    color: var(--foreground);
    border-color: var(--accent);
  }
  .banner--error {
    background: color-mix(in oklab, var(--destructive) 18%, var(--background));
    color: var(--foreground);
    border-color: var(--destructive);
  }
</style>
